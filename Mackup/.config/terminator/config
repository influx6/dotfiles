[global_config]
[keybindings]
  copy = <Super>c
  paste = <Super>v
  split_horiz = <Primary>l
  split_vert = <Primary>k
[layouts]
  [[default]]
    [[[child1]]]
      parent = window0
      type = Terminal
    [[[window0]]]
      parent = ""
      type = Window
[plugins]
[profiles]
  [[default]]
    cursor_color = "#aaaaaa"
