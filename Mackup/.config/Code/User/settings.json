		"**/vendor/{[^l],?[^ai]}*": true,
		// Hide everything in /public, except "index.php"
		"**/public/{[^i],?[^n]}*": true,
		"**/dist": true,
		"**/_ide_helper.php": true,
		"**/composer.lock": true,
		"**/package-lock.json": true,
		"storage": true,
		".phpunit.result.cache": true
